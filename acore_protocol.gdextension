[configuration]

entry_symbol = "acore_protocol_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]

linux.debug.x86_64 = "res://bin/libacore_godot_protocol.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libacore_godot_protocol.linux.template_debug.x86_64.so"
